# Crystal Tech API — Apache rewrite rules for cPanel.
# All /api/* requests funnel through public/index.php (PHP front controller).

RewriteEngine On

# Don't rewrite for real files (lets you drop static helpers in /api/public/ if needed)
RewriteCond %{REQUEST_FILENAME} -f [OR]
RewriteCond %{REQUEST_FILENAME} -d
RewriteRule ^ - [L]

# Send everything else into index.php
RewriteRule ^ index.php [QSA,L]

# Security headers
<IfModule mod_headers.c>
    Header set X-Content-Type-Options "nosniff"
    Header set X-Frame-Options "SAMEORIGIN"
    Header set Referrer-Policy "strict-origin-when-cross-origin"
</IfModule>

# Block direct access to PHP files outside public/
<FilesMatch "\.(env|sql|log|md)$">
    Require all denied
</FilesMatch>
